.PHONY: dev deploy preview clean

# ─── Development ─────────────────────────────────────────────────────────────
dev:
	vercel dev

# ─── Deploy to preview ──────────────────────────────────────────────────────
preview:
	vercel

# ─── Deploy to production ───────────────────────────────────────────────────
deploy:
	vercel --prod

# ─── Clean ───────────────────────────────────────────────────────────────────
clean:
	rm -rf .vercel
